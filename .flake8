[flake8]
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    venv,
    env,
    .venv,
    .env,
    *.egg-info,
    .eggs,
    .mypy_cache,
    .pytest_cache,
    .tox,
    docs/conf.py,
    tests/
ignore = C901, E128, E227, E228, E301, E302, E305, E501, E701, E702, F401, W292
select = C, E, F, W
