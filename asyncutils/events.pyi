    def get(self, strict: Literal[False]) -> T|None: ...
    @overload
    def get(self, strict: Literal[True]=...) -> T: ...
    async def wait_for_next(self, timeout: float|None=...) -> T: ...
    def is_set(self) -> bool: ...
    @property
    def history(self) -> list[tuple[float, T]]: ...
    @property
    def history_asdict(self) -> dict[float, T]: ...
    def recent_history(self, duration: float|None=...) -> Generator[tuple[float, T], None, None]: ...
    async def wait_for_transition(self, old: T, new: T, timeout: float|None=..., *, force_transition: bool=...) -> bool: ...
    async def wait_for_transition_unordered(self, a: T, b: T, timeout: float|None=..., *, force_transition: bool=..., loop: AbstractEventLoop|None=...) -> bool: ...