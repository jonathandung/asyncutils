    def release_returned_false(self, lock: AsyncLockLike[Any], /) -> bool: ...
    def preliminary_check_lock(self, lock: AsyncLockLike[Any], /) -> bool: ...
    def can_force_lock_held(self, lock: AsyncLockLike[Any], /) -> bool: ...
    def patch_owner(self, task: Task[Any], lock: AsyncLockLike[Any], /) -> None: ...
    def answer_received(self, lock: AsyncLockLike[Any], answer: Any, /) -> None: ...
