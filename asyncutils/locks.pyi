    async def host[T](self, task: Awaitable[T], lock: AsyncLockLike[Any], /, *, timeout1: float|None=..., timeout2: float|None=..., timeout3: float|None) -> T: ...
    async def _wait_on[T](self, task: Awaitable[T], lock: AsyncLockLike[Any], /) -> T: ...
    async def get_info(self, lock: AsyncLockLike[Any], /) -> Any: ...
