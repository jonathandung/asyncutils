'''| Backport of :class:`asyncio.queues.Queue` with a :meth:`~asyncio.queues.Queue.shutdown` method to python 3.12 or under.
| Error messages are kept in line with those in the standard library for consistency.'''
import asyncio, sys
assert sys.version_info < (3, 13)
__all__ = 'LifoQueue', 'PriorityQueue', 'Queue', 'QueueEmpty', 'QueueFull', 'QueueShutDown'
class QueueEmpty(Exception): ...
class QueueFull(Exception): ...
class QueueShutDown(Exception): ...
class Queue[T](asyncio.Queue[T]):
    def shutdown(self, immediate: bool=...) -> None: '''Shut down the queue, disallowing items from being added. If `immediate` is `True`, all pending :meth:`~asyncio.queues.Queue.get` calls will be cancelled immediately and future calls will fail, even if there were items in the queue.'''
class LifoQueue[T](Queue[T]): ...
class PriorityQueue[T](Queue[T]): ...